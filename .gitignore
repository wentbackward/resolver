# Build outputs
/resolver
/resolver-duckdb
/dist/

# Reports are ephemeral per-run — except the canonical community-benchmarks
# YAML, which is hand-maintained append-only reference data (see
# docs/archive/community-benchmarks-schema.md). Note: re-including a child of an
# ignored directory only works if the directory itself isn't excluded —
# hence /reports/* (contents) rather than /reports/ (the dir).
/reports/*
!/reports/community-benchmarks.yaml

# OMC local state (worktree ephemera); keep skills/specs/plans.
# `**/` so patterns also catch nested .omc/ dirs
# (e.g. tools/analyze/.omc/state/).
**/.omc/state/
**/.omc/sessions/
**/.omc/logs/
**/.omc/drafts/
**/.omc/prd.json
**/.omc/progress.txt
**/.omc/project-memory.json

# Reporting workspace — per-checkout venv, duckdb-tagged binary, user
# notebook copies. Created by scripts/report.sh. Safe to delete.
/.reporting/

# Claude Code local (user-specific) overrides
/.claude/settings.local.json

# Editor-local settings
/.vscode/
/.idea/

# Editor / OS
*.swp
*.swo
*.tmp
.DS_Store

# Go
*.test
*.out
vendor/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/
.venv/
.python-version
/judge-replay
